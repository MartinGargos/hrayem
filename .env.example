# =============================================================================
# Hrayem — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. Only .env.example is committed.
#
# Where to find these values:
#   Supabase → Project Settings → API
#   Expo → eas.json / EAS dashboard (projectId only)
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase — Client (safe to expose, bundled into the app binary)
# -----------------------------------------------------------------------------

# Your Supabase project URL
# Example: https://xyzxyzxyz.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://mslceoipidrgdblhovep.supabase.co

# Supabase anon/public key — safe for client use, RLS enforces access control
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_u8CtZh7nDwsAyhtW19BpoQ_5sUn-D0I


# -----------------------------------------------------------------------------
# Supabase — Server only (NEVER expose to client or commit with real values)
# Used exclusively in Supabase Edge Functions via Supabase project secrets.
# Do NOT prefix with EXPO_PUBLIC_.
# Set these in: Supabase Dashboard → Edge Functions → Secrets
# -----------------------------------------------------------------------------

# Supabase service role key — bypasses RLS, server only
SUPABASE_SERVICE_ROLE_KEY=

# Supabase DB connection string — for running migrations locally if needed
# Supabase → Project Settings → Database → Connection string (URI)
SUPABASE_DB_URL=


# -----------------------------------------------------------------------------
# Expo Push Notifications
# Used in Edge Functions to send authenticated push requests to Expo's API.
# Generate at: https://expo.dev/accounts/[your-account]/settings/access-tokens
# Set this in Supabase Edge Function secrets, not in the app.
# -----------------------------------------------------------------------------

EXPO_PUSH_ACCESS_TOKEN=


# -----------------------------------------------------------------------------
# App config (optional overrides — normally set in app.json / app.config.js)
# -----------------------------------------------------------------------------

# Expo project ID — set automatically by `eas init`, found in app.json
# Listed here for reference only; do not override unless you know why.
# EXPO_PROJECT_ID=
