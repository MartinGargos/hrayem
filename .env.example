# Client (bundled in app — safe to expose)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
EXPO_PUBLIC_TERMS_VERSION=2025-06-01
EXPO_PUBLIC_PRIVACY_VERSION=2025-06-01
EXPO_PUBLIC_WEB_BASE_URL=https://hrayem.cz
EXPO_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/id6761645539
EXPO_PUBLIC_PLAY_STORE_URL=

# Edge Functions only — never exposed to client
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
EXPO_PUSH_ACCESS_TOKEN=your-expo-push-access-token
UPSTASH_REDIS_REST_URL=https://your-redis-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
EVENT_REMINDER_DISPATCH_SECRET=your-internal-reminder-dispatch-secret
ADMIN_REPORT_EMAIL=ops@example.com
RESEND_API_KEY=re_your-resend-api-key
REPORT_EMAIL_FROM=Hrayem Reports <reports@your-domain.example>

