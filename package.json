{
  "name": "hrayem",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "bash ./scripts/with-node20.sh expo start",
    "android": "bash ./scripts/with-node20.sh expo start --android",
    "ios": "bash ./scripts/with-node20.sh expo start --ios",
    "web": "bash ./scripts/with-node20.sh expo start --web",
    "lint": "bash ./scripts/with-node20.sh eslint . --ext .ts,.tsx,.js,.jsx",
    "typecheck": "bash ./scripts/with-node20.sh tsc --noEmit",
    "format": "bash ./scripts/with-node20.sh prettier . --write",
    "format:check": "bash ./scripts/with-node20.sh prettier . --check",
    "doctor": "bash ./scripts/with-node20.sh npx expo-doctor",
    "export:check": "bash ./scripts/with-node20.sh expo export --platform android --platform ios"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-native-community/netinfo": "11.5.2",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tanstack/react-query": "^5.95.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "expo": "~55.0.8",
    "expo-constants": "~55.0.9",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-linking": "~55.0.8",
    "expo-localization": "~55.0.9",
    "expo-secure-store": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "i18next": "^25.10.8",
    "react": "19.2.0",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^16.6.5",
    "react-native": "0.83.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eslint": "^9.39.1",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "expo-doctor": "^1.18.13",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "packageManager": "pnpm@10.13.1",
  "private": true
