    "@react-navigation/native": "^7.2.1",
    "@react-navigation/native-stack": "^7.14.9",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tanstack/react-query": "^5.95.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "expo": "~55.0.8",
    "expo-constants": "~55.0.9",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-image-manipulator": "~55.0.11",
    "expo-image-picker": "~55.0.13",
    "expo-linking": "~55.0.8",
    "expo-localization": "~55.0.9",
    "expo-location": "~55.1.4",
    "expo-notifications": "~55.0.13",
    "expo-secure-store": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.10",
    "i18next": "^25.10.8",
    "react": "19.2.0",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^16.6.5",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
